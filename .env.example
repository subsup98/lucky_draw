# 이 파일은 템플릿입니다. 복사해서 `.env`로 만들고 실제 값을 채워 주세요.
# 실제 `.env`는 커밋하지 마세요(.gitignore에 포함).

# --- Backend ---
NODE_ENV=development
BACKEND_PORT=4000

# --- PostgreSQL ---
POSTGRES_USER=lucky_draw
POSTGRES_PASSWORD=lucky_draw_dev_pw
POSTGRES_DB=lucky_draw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lucky_draw:lucky_draw_dev_pw@localhost:5432/lucky_draw?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Auth (개발용 기본값 — 운영은 반드시 교체) ---
JWT_ACCESS_PRIVATE_KEY_PATH=./keys/access_private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS_USER=1209600
REFRESH_TTL_SECONDS_ADMIN=86400
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=lucky_draw
